---
import Icon from "./Icon.astro";

interface Props { languageHref?: string; }
const { languageHref = "/en/" } = Astro.props;

const columns = [
  {
    title: "Kurumsal",
    href: "/kurumsal/",
    items: [
      { label: "Hakkımızda", href: "/hakkimizda/" },
      { label: "Vizyon & Misyon", href: "/vizyon-misyon/" },
      { label: "Kalite Politikamız", href: "/kalite-politikamiz/" },
      { label: "Sertifikalar", href: "/sertifikalar/" },
      { label: "Referanslar", href: "/referanslar/" },
    ],
  },
  {
    title: "Uzmanlıklar",
    href: "/uzmanliklar/",
    items: [
      { label: "Proses Tasarım ve Simülasyon", href: "/uzmanliklar/proses-tasarim-ve-simulasyon/" },
      { label: "Mekanik Tasarım", href: "/uzmanliklar/mekanik-tasarim/" },
      { label: "3D Ölçüm ve Kalite Kontrol", href: "/uzmanliklar/3d-olcum-ve-kalite-kontrol/" },
      { label: "Talaşlı İmalat", href: "/uzmanliklar/talasli-imalat/" },
      { label: "Mekanik – Elektrik İmalat", href: "/uzmanliklar/mekanik-elektrik-imalat/" },
      { label: "Elektrik Projelendirme", href: "/uzmanliklar/elektrik-projelendirme/" },
      { label: "Otomasyon Yazılım", href: "/uzmanliklar/otomasyon-yazilim/" },
      { label: "Robot Yazılımı ve Offline Programlama", href: "/uzmanliklar/robot-yazilimi-ve-offline-programlama/" },
      { label: "Sistem Kurulum ve Devreye Alma", href: "/uzmanliklar/sistem-kurulum-ve-devreye-alma/" },
    ],
  },
  {
    title: "Teknolojiler",
    href: "/teknolojiler/",
    items: [
      { label: "Kaynak Teknolojileri", href: "/teknolojiler/kaynak-teknolojileri/" },
      { label: "Taşıma Sistemleri", href: "/teknolojiler/tasima-sistemleri/" },
      { label: "Montaj Sistemleri", href: "/teknolojiler/montaj-sistemleri/" },
      { label: "Mastikleme / Dozajlama Sistemleri", href: "/teknolojiler/mastikleme-dozajlama-sistemleri/" },
      { label: "İşbirlikçi Robotlu Sistemler", href: "/teknolojiler/isbirlikci-robotlu-sistemler/" },
    ],
  },
];
---

<div class="rota-menu-desktop" aria-label="Masaüstü menüsü">
  <div class="rota-menu-desktop__grid">
    {columns.map((column) => (
      <section class="rota-menu-desktop__column">
        <a class="rota-menu-desktop__title" href={column.href} title={`${column.title} sayfasını inceleyin`}>{column.title}<i aria-hidden="true"></i></a>
        <div class="rota-menu-desktop__links">
          {column.items.map((item) => (
            <a href={item.href} title={`${item.label} sayfasını inceleyin`}><span aria-hidden="true">›</span>{item.label}</a>
          ))}
        </div>
      </section>
    ))}

    <section class="rota-menu-desktop__column rota-menu-desktop__contact">
      <a class="rota-menu-desktop__title" href="/iletisim/" title="İletişim sayfasını açın">İletişim<i aria-hidden="true"></i></a>
      <a class="rota-menu-desktop__form-link" href="/iletisim/" title="İletişim formunu açın"><span aria-hidden="true">›</span>İletişim Formu</a>
      <div class="rota-menu-desktop__address">
        <strong>ROTA ROBOTİK</strong>
        <p>Yarış Çıkmazı Sokak No:1<br />Bağımsız Bölüm No:347<br />İSTİM Tuzla / İstanbul</p>
        <a href="https://wa.me/905387788118" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp üzerinden iletişime geçin"><Icon name="whatsapp" />+90 538 778 81 18</a>
        <a href="mailto:info@rotarobotik.com"><Icon name="envelope" />info@rotarobotik.com</a>
      </div>
    </section>
  </div>

  <div class="rota-menu-desktop__footer">
    <p><i aria-hidden="true"></i>MÜHENDİSLİKLE GELECEĞİ TASARLIYORUZ</p>
    <div class="rota-menu-desktop__footer-actions">
      <div class="rota-menu-desktop__socials" aria-label="Sosyal medya">
        <a href="https://www.linkedin.com/company/rota-robotik-sistemler/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><Icon name="linkedin" /></a>
        <a href="https://wa.me/905387788118" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"><Icon name="whatsapp" /></a>
      </div>
      <a class="rota-menu-desktop__language" href={languageHref} hreflang="en">EN <span aria-hidden="true">⌄</span></a>
    </div>
  </div>
</div>
